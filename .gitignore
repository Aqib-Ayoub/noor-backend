# ── Environment variables (NEVER commit secrets) ──────────────────────────────
.env
.env.local
.env.*.local

# ── Dependencies (reinstall with npm install) ──────────────────────────────────
node_modules/

# ── Compiled output (regenerate with npm run build) ───────────────────────────
dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# ── TypeScript build info cache ───────────────────────────────────────────────
*.tsbuildinfo